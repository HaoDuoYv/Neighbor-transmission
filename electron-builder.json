{
  "appId": "com.linchuan.app",
  "productName": "邻传",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*"
  ],
  "asarUnpack": [
    "node_modules/better-sqlite3/**",
    "node_modules/electron-store/**"
  ],
  "win": {
    "target": "nsis"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "邻传"
  },
  "npmRebuild": true
}
