{
  "name": "linchuan",
  "version": "1.0.0",
  "description": "局域网文件传输与聊天应用",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
